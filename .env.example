# Zulip Instance
ZULIP_SERVER_URL=https://your-org.zulipchat.com

# Bot Account (for basic integration testing)
ZULIP_BOT_EMAIL=your-bot@your-org.zulipchat.com
ZULIP_BOT_API_KEY=your-bot-api-key-here

# User Account (for agent-as-user testing)
ZULIP_USER_EMAIL=your-user@your-org.zulipchat.com
ZULIP_USER_API_KEY=your-user-api-key-here
