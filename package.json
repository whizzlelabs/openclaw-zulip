{
  "name": "openclaw-zulip",
  "version": "0.1.0",
  "description": "OpenClaw channel plugin for Zulip — clean-room implementation with ACP topic bindings",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepare": "husky"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "openclaw-channel",
    "zulip"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "openclaw": "^2026.3.28",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
