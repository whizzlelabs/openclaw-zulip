{
  "name": "openclaw-zulip",
  "version": "0.1.1",
  "description": "OpenClaw channel plugin for Zulip — clean-room implementation with ACP topic bindings",
  "license": "MIT",
  "author": "whizzlefred",
  "repository": {
    "type": "git",
    "url": "https://github.com/whizzlelabs/openclaw-zulip.git"
  },
  "bugs": {
    "url": "https://github.com/whizzlelabs/openclaw-zulip/issues"
  },
  "homepage": "https://github.com/whizzlelabs/openclaw-zulip#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src/",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "prepare": "husky"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "openclaw-channel",
    "zulip"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "openclaw": "^2026.3.28",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  }
}
